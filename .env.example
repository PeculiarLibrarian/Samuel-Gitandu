# PADI Sovereign Bureau - Environment Configuration

# Primary Provider: Alchemy Base Mainnet
ALCHEMY_API_KEY=your_actual_api_key_from_test

# (Optional) Alchemy Base Sepolia for testing
ALCHEMY_SEPOLIA_API_KEY=your_sepolia_key_if_available

# PADI Bureau Configuration
PADI_NODE_LOCATION=Nairobi-01
PADI_DEFAULT_NETWORK=testnet
PADI_MAX_DRIFT_SECONDS=5
PADI_BLOCK_REFRESH_INTERVAL=15

# Logging
PADI_LOG_LEVEL=INFO
PADI_DETAILED_LOGS=false

# 1003 Rule Enforcement
PADI_CONFIDENCE_THRESHOLD=1.0
PADI_REQUIRED_VERIFICATION_SOURCES=3
