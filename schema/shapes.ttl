@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix ex: <http://padi.u/schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

# =====================================================
# 🏛️ PADI SHACL SHAPE — FINAL PRODUCTION VALIDATION
# =====================================================

ex:OpportunityShape a sh:NodeShape ;
    sh:targetClass ex:FinancialSignal ;
    rdfs:label "Financial Signal Validator" ;
    rdfs:comment "Validates FinancialSignal and ExecutableFact instances according to the 1003 Rule, targeting layer, identity, and infrastructure context." ;

    # ---------------------------
    # RULE 1: Confidence (The "1")
    # ---------------------------
    sh:property [
        sh:path ex:hasConfidence ;
        sh:datatype xsd:decimal ;
        sh:minInclusive 1.0 ;
        sh:maxInclusive 1.0 ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:name "Deterministic Confidence" ;
        rdfs:comment "Confidence must exist exactly once and have a value of 1.0." ;
    ] ;

    # ---------------------------
    # RULE 2: Verification Sources (The "3")
    # ---------------------------
    sh:property [
        sh:path ex:hasVerificationSource ;
        sh:datatype xsd:string ;
        sh:minCount 3 ;
        sh:maxCount 3 ;
        sh:name "Triple-Source Verification" ;
        rdfs:comment "Exactly 3 independent verification sources are required for the 1003 Rule." ;
    ] ;

    # ---------------------------
    # TARGETING PROPERTIES (0 CONFLICT LAYER)
    # ---------------------------
    sh:property [
        sh:path ex:hasTargetAddress ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:name "Target Contract Address" ;
        rdfs:comment "The contract or wallet address targeted by this signal; single occurrence." ;
    ] ;

    sh:property [
        sh:path ex:hasActionType ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:name "Action Type" ;
        rdfs:comment "The specific action type of this signal (e.g., SWAP, ARB, AUDIT); single occurrence." ;
    ] ;

    # ---------------------------
    # IDENTITY & TRACEABILITY
    # ---------------------------
    sh:property [
        sh:path ex:hasSignalID ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:name "Signal Identifier" ;
        rdfs:comment "Unique deterministic identifier for the signal (e.g., SHA256 hash); single occurrence." ;
    ] ;

    sh:property [
        sh:path ex:observedAt ;
        sh:datatype xsd:dateTime ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:name "Observation Timestamp" ;
        rdfs:comment "Timestamp when the signal was observed; single occurrence, ideally in UTC." ;
    ] ;

    # ---------------------------
    # INFRASTRUCTURE CONTEXT (BASE L2)
    # ---------------------------
    sh:property [
        sh:path ex:atBlockNumber ;
        sh:datatype xsd:integer ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:name "Block Number" ;
        rdfs:comment "The blockchain/mempool block number where the signal was observed." ;
    ] ;

    sh:property [
        sh:path ex:hasGasPriceGwei ;
        sh:datatype xsd:decimal ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:name "Gas Price (Gwei)" ;
        rdfs:comment "Gas price at the time of observation, in Gwei; single occurrence." ;
    ] ;

    sh:property [
        sh:path ex:isValidated ;
        sh:datatype xsd:boolean ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:name "Validation Status" ;
        rdfs:comment "Indicates whether the signal passed validation (true/false); single occurrence." ;
    ] .
