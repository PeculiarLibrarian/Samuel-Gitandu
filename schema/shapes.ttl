@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix ex: <http://padi.u/schema#> .

ex:OpportunityShape a sh:NodeShape ;
    sh:targetClass ex:ScoutedOpportunity ;
    # RULE 1: Confidence MUST be 1.0
    sh:property [
        sh:path ex:hasConfidence ;
        sh:minInclusive 1.0 ;
        sh:maxInclusive 1.0 ;
        sh:minCount 1 ;
    ] ;
    # RULE 2: MUST have exactly 3 sources (The 1003 Rule)
    sh:property [
        sh:path ex:hasSource ;
        sh:minCount 3 ;
        sh:maxCount 3 ;
    ] .
