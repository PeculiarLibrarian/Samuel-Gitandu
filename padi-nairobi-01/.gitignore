# =====================================================
# .gitignore — PADI Nairobi-01 Production
# =====================================================
# Version: 1.0-PROD
# Node: Nairobi-01
# =====================================================

# =====================================================
# Security — Sensitive Files (NEVER COMMIT)
# =====================================================
monitoring/alertmanager/.env
executor/config/alchemy.json
*.env
*.key
*.pem
*.p12
*.pkcs12

# =====================================================
# Logs
# =====================================================
*.log
*.log.*
logs/
**/logs/

# =====================================================
# Docker Data
# =================================================<arg_value>**data/**
**/*-data/
.docker/

# =====================================================
# Temporary Files
# =====================================================
*.tmp
*.temp
*.swp
*.swo
*~

# =====================================================
# OS Files
# =====================================================
.DS_Store
Thumbs.db
desktop.ini

# =====================================================
# Editor Files
# =====================================================
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# =====================================================
# Build Artifacts
# =====================================================
dist/
build/
target/
node_modules/
