      },
      "gridPos": { "h": 6, "w": 4, "x": 12, "y": 0 },
      "id": 4,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showThresholdMarkers": true
      },
      "targets": [
        { "expr": "((padi_bureau_tvl_usd{node=\"$node\"} / padi_bureau_target_tvl_usd{node=\"$node\"}) * 100) or vector(0)", "instant": true, "refId": "A" }
      ],
      "title": "TVL % of Target",
      "type": "gauge"
    },
