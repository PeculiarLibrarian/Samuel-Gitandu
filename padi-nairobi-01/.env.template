# =====================================================
# PADI EXECUTOR v5.3 — Environment Configuration
# =====================================================

# Wallet Configuration
PADI_WALLET_ADDRESS=0x...
PADI_PRIVATE_KEY=0x...

# Node Configuration
PADI_NODE_ID=Nairobi-01
PADI_SIMULATION_MODE=false

# RPC Endpoints (Mainnet)
PADI_OP_MAINNET_RPC=https://...
PADI_OP_SEPOLIA_RPC=https://...
PADI_ETH_MAINNET_RPC=https://...
PADI_ETH_SEPOLIA_RPC=https://...
PADI_BASE_L2_RPC=https://...

# Backup RPCs (Optional)
PADI_OP_MAINNET_RPC_BACKUP=https://...
PADI_OP_SEPOLIA_RPC_BACKUP=https://...

# Circuit Breaker Configuration
PADI_CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
PADI_CIRCUIT_BREAKER_SUCCESS_THRESHOLD=3
PADI_CIRCUIT_BREAKER_TIMEOUT_SECONDS=300

# Gas Configuration
PADI_GAS_SPIKE_THRESHOLD=2.5
PADI_GAS_WARNING_THRESHOLD=1000
PADI_PRIORITY_FEE_GWEI=1.5
PADI_GAS_CACHE_TTL=300

# Receipt Tracking Configuration
PADI_RECEIPT_MONITOR_ENABLED=true
PADI_RECEIPT_CHECK_INTERVAL_SECONDS=30
PADI_RECEIPT_STUCK_THRESHOLD_MINUTES=5
PADI_RECEIPT_ABANDON_THRESHOLD_MINUTES=15
PADI_RECEIPT_MAX_REBROADCAST=3
PADI_RECEIPT_GAS_ESCALATION_PERCENT=20

# RDF Snapshot Configuration
PADI_RDF_MAX_SNAPSHOTS=1000
PADI_RDF_AUTO_EXPORT_INTERVAL=100

# Logging Configuration
PADI_LOG_LEVEL=INFO
PADI_LOG_TO_FILE=true
PADI_LOG_DIR=logs

# =====================================================
# SECURITY NOTES:
# - Never commit .env to version control
# - Rotate private keys regularly
# - Use hardware wallets for high-value operations
# - Monitor logs for unusual activity
# =====================================================
